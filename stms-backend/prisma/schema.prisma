generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String       @id @default(uuid()) @db.Uuid
  name         String       @db.VarChar(150)
  email        String       @unique @db.VarChar(100)
  passwordHash String       @map("password_hash") @db.VarChar(255)
  phoneNumber  String       @map("phone_number") @db.VarChar(20)
  role         String       @db.VarChar(30)
  createdAt    DateTime     @default(now()) @map("created_at") @db.Timestamp()

  registrants      Registrant[]
  gradesUpdated    Grade[]       @relation("GradesUpdatedBy")
  certificates     Certificate[] @relation("PoldaApprover")
  certsIssued      Certificate[] @relation("CertificateIssuer")
  auditTrails      AuditTrail[]

  @@map("users")
}

model TrainingBatch {
  id        String   @id @default(uuid()) @db.Uuid
  batchName String   @map("batch_name") @db.VarChar(100)
  type      String   @default("Satpam Umum") @db.VarChar(50)
  startDate DateTime @map("start_date") @db.Date
  endDate   DateTime @map("end_date") @db.Date
  quota     Int
  status    String   @default("OPEN") @db.VarChar(20)

  registrants Registrant[]
  schedules   Schedule[]
  attendance  Attendance[]

  @@map("training_batches")
}

model Registrant {
  id                 String   @id @default(uuid()) @db.Uuid
  userId             String   @map("user_id") @db.Uuid
  batchId            String   @map("batch_id") @db.Uuid
  ktpNumber          String   @map("ktp_number") @db.VarChar(16)
  educationLevel     String   @map("education_level") @db.VarChar(30)
  documentUrls       Json     @map("document_urls")
  statusRegistration String   @default("PENDING_VERIFICATION") @map("status_registration") @db.VarChar(30)
  paymentStatus      String   @default("UNPAID") @map("payment_status") @db.VarChar(30)
  paymentAmount      Decimal? @map("payment_amount") @db.Decimal(12, 2)
  paymentDate        DateTime? @map("payment_date") @db.Timestamp()
  paymentNote        String?  @map("payment_note") @db.VarChar(255)
  verifiedBy         String?  @map("verified_by") @db.Uuid
  createdAt          DateTime @default(now()) @map("created_at") @db.Timestamp()

  user        User          @relation(fields: [userId], references: [id])
  batch       TrainingBatch @relation(fields: [batchId], references: [id])
  grade       Grade?
  certificate Certificate?
  attendance  Attendance[]

  @@map("registrants")
}

model Attendance {
  id           String   @id @default(uuid()) @db.Uuid
  registrantId String   @map("registrant_id") @db.Uuid
  batchId      String   @map("batch_id") @db.Uuid
  date         DateTime @db.Date
  status       String   @default("ABSENT") @db.VarChar(10)
  checkIn      String?  @map("check_in") @db.VarChar(5)
  checkOut     String?  @map("check_out") @db.VarChar(5)
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamp()

  registrant Registrant    @relation(fields: [registrantId], references: [id])
  batch      TrainingBatch @relation(fields: [batchId], references: [id])

  @@unique([registrantId, batchId, date])
  @@map("attendance")
}

model Grade {
  id                 String   @id @default(uuid()) @db.Uuid
  registrantId       String   @unique @map("registrant_id") @db.Uuid
  theoryScore        Decimal  @default(0.0) @map("theory_score") @db.Decimal(5, 2)
  physicalScore      Decimal  @default(0.0) @map("physical_score") @db.Decimal(5, 2)
  specialSkillsScore Decimal  @default(0.0) @map("special_skills_score") @db.Decimal(5, 2)
  subjectScores      Json     @default("{}") @map("subject_scores")
  finalStatus        String   @default("PENDING") @map("final_status") @db.VarChar(20)
  updatedBy          String   @map("updated_by") @db.Uuid

  registrant Registrant @relation(fields: [registrantId], references: [id])
  updater    User       @relation("GradesUpdatedBy", fields: [updatedBy], references: [id])

  @@map("grades")
}

model Certificate {
  id                String    @id @default(uuid()) @db.Uuid
  registrantId      String    @unique @map("registrant_id") @db.Uuid
  certificateNumber String    @unique @map("certificate_number") @db.VarChar(100)
  verificationToken String    @unique @map("verification_token") @db.VarChar(64)
  filePath          String    @map("file_path")
  issuedAt          DateTime  @default(now()) @map("issued_at") @db.Timestamp()
  issuedById        String    @map("issued_by_id") @db.Uuid
  poldaApproverId   String?   @map("polda_approver_id") @db.Uuid
  signedAt          DateTime? @map("signed_at") @db.Timestamp()

  registrant    Registrant @relation(fields: [registrantId], references: [id])
  issuedBy      User       @relation("CertificateIssuer", fields: [issuedById], references: [id])
  poldaApprover User?      @relation("PoldaApprover", fields: [poldaApproverId], references: [id])

  @@map("certificates")
}

model AuditTrail {
  id         String   @id @default(uuid()) @db.Uuid
  userId     String   @map("user_id") @db.Uuid
  action     String   @db.VarChar(100)
  tableName  String   @map("table_name") @db.VarChar(50)
  beforeData Json?    @map("before_data")
  afterData  Json?    @map("after_data")
  ipAddress  String?  @map("ip_address") @db.VarChar(45)
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamp()

  user User @relation(fields: [userId], references: [id])

  @@map("audit_trails")
}

model SystemSetting {
  key   String @id @db.VarChar(100)
  value String @db.Text

  @@map("system_settings")
}

model Schedule {
  id         String   @id @default(uuid()) @db.Uuid
  batchId    String   @map("batch_id") @db.Uuid
  day        String   @db.VarChar(10)
  subject    String   @db.VarChar(150)
  instructor String   @db.VarChar(150)
  room       String   @db.VarChar(50)
  start      String   @db.VarChar(5)
  end        String   @db.VarChar(5)
  type       String   @db.VarChar(20)
  week       Int?
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamp()

  batch TrainingBatch @relation(fields: [batchId], references: [id])

  @@map("schedules")
}

model ServiceRate {
  id           String   @id @default(uuid()) @db.Uuid
  trainingType String   @unique @map("training_type") @db.VarChar(50)
  amount       Decimal  @db.Decimal(12, 2)
  description  String?  @db.VarChar(255)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamp()
  updatedAt    DateTime @updatedAt @map("updated_at") @db.Timestamp()

  @@map("service_rates")
}

model Role {
  id          String   @id @default(uuid()) @db.Uuid
  name        String   @unique @db.VarChar(50)
  description String?  @db.VarChar(255)
  permissions Json     @default("[]")
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamp()
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamp()

  @@map("roles")
}
